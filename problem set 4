def iter_even():
    i=0
    while True:  
        if i%2==0:
            yield i 
        i+=1
for i in iter_even():
    print(i)
    if i>10:
        break
#2
def iter_odd():
    i=0
    while True:  
        if i%2==1:
            yield i 
        i+=1
for i in iter_odd():
    print(i)
    if i>10:
        break
#3
def iter_power(k):
    i=0
    while True:  
        yield k**i 
        i+=1
for i in iter_power(2):
    print(i)
    if i>10:
        break    
