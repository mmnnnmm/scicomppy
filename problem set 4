def reverse_range(L, l, r):
    if l>=r:
        return L
    L[l],L[r]=L[r],L[l]
    return reverse_range(L, l+1, r-1)

def reverse_range1(L, l, r):
    while l<r:
        L[l],L[r]=L[r],L[l]
        l+=1
        r-=1
    return L
A=list(range (10))
print(reverse_range(A, 3, 6))
print(reverse_range1(A, 2, 3))

